{
  "name": "Jellyfin",
  "desc": "A simple media server",
  "desc_long": [
    "## Jellyfin - Your Personal Media Server",
    "",
    "Take control of your entertainment. Jellyfin is a free, open-source media server that transforms your personal",
    "collection of movies, TV shows, music, and photos into a beautiful, Netflix-like experience across all your devices.",
    "",
    "### Key Features",
    "",
    "- **No subscriptions, no ads, no tracking** - complete privacy and control",
    "- **Stream anywhere** - watch on phones, tablets, computers, smart TVs, and more",
    "- **Self-hosted** - runs on your own hardware, fully under your control",
    "- **Smart organization** - automatic metadata, artwork, ratings, and watch history",
    "- **Share with family** - invite others with customizable permissions",
    "",
    "Free and open-source. Works on Windows, Mac, Linux, and NAS devices. Your content, your rules."
  ],
  "alternatives": ["youtube", "netflix", "apple tv", "amazon prime video", "prime video", "zee5", "sonyliv", "bilibili",
    "peacock", "iflix", "mango tv", "vidio", "mgm+", "disney+", "hulu", "jiohotstar", "hbo max", "discovery+", "youku",
    "paramount+", "skyshowtime", "bet+", "tencent video", "deezer", "spotify", "apple music", "qq music", "youTube music",
    "amazon music", "netease cloud music", "pandora", "tidal", "soundcloud", "gaana", "iheartradio"],
  "tags": ["streaming", "movies", "music", "media server"],
  "category": "media",
  "category_icon": "Monitor",
  "website": "https://jellyfin.org",
  "docker_image": "jellyfin/jellyfin",
  "version": "10.11.7",
  "domain": "jellyfin",
  "events": {
    "setup": {
      "label": "Setup Jellyfin",
      "type": "script/sh",
      "src": "/scripts/setup.sh"
    },
    "login": {
      "label": "Log a user into Jellyfin",
      "type": "script/js",
      "src": "/scripts/login.js",
      "trigger_type": "match/url",
      "trigger_src": ".*\\/Users\\/authenticatebyname",
      "result_type": "injection/client/json"
    }
  },
  "apps": {
    "official": {
      "desktop": {
        "arm64": {
          "windows": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-windows/main/windows-arm64.zip",
          "mac": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-macos/main/macos-arm64.zip"
        },
        "amd64": {
          "windows": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-windows/main/windows-x64.zip",
          "mac": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-macos/main/macos-x86_64.zip"
        },
        "all": {
          "linux": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-linux-appimage/main/linux-appimage-x86_64.zip",
          "android": "https://f-droid.org/packages/org.jellyfin.mobile/",
          "ios": "https://apps.apple.com/fr/app/jellyfin-mobile/id1480192618"
        }
      }
    },
    "third_party": {
