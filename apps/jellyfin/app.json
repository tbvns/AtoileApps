{
  "name": "Jellyfin",
  "desc": "A simple media server",
  "alternatives": ["youtube", "netflix", "apple tv", "amazon prime video", "prime video", "zee5", "sonyliv", "bilibili",
    "peacock", "iflix", "mango tv", "vidio", "mgm+", "disney+", "hulu", "jiohotstar", "hbo max", "discovery+", "youku",
    "paramount+", "skyshowtime", "bet+", "tencent video", "deezer", "spotify", "apple music", "qq music", "youTube music",
    "amazon music", "netease cloud music", "pandora", "tidal", "soundcloud", "gaana", "iheartradio"],
  "tags": ["streaming", "movies", "music", "media server"],
  "category": "media",
  "category_icon": "Monitor",
  "website": "https://jellyfin.org",
  "docker_image": "jellyfin/jellyfin",
  "version": "10.11.7",
  "domain": "jellyfin",
  "events": {
    "setup": {
      "label": "Setup Jellyfin",
      "type": "script/sh",
      "src": "/scripts/setup.sh"
    },
    "login": {
      "label": "Log a user into Jellyfin",
      "type": "script/js",
      "src": "/scripts/login.js",
      "trigger_type": "match/url",
      "trigger_src": ".*\\/Users\\/authenticatebyname",
      "result_type": "injection/client/json"
    }
  },
  "apps": {
    "official": {
      "web": "http://jellyfin.local/web/",
      "windows (x64)": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-windows/main/windows-x64.zip",
      "windows (arm64)": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-windows/main/windows-arm64.zip",
      "mac (silicon)": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-macos/main/macos-arm64.zip",
      "mac (intel)": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-macos/main/macos-x86_64.zip",
      "linux": "https://nightly.link/jellyfin/jellyfin-desktop/workflows/build-linux-appimage/main/linux-appimage-x86_64.zip"
    },
    "third_party": {
      "Finamp (Audio)": {
        "android": "https://f-droid.org/packages/com.unicornsonlsd.finamp/",
        "ios": "https://apps.apple.com/us/app/finamp/id1574922594"
      },
      "Feishin (Audio)": {
        "windows": "https://github.com/jeffvli/feishin/releases/latest",
        "mac": "https://github.com/jeffvli/feishin/releases/latest",
        "linux": "https://github.com/jeffvli/feishin/releases/latest"
      }
    },
    "more": "https://jellyfin.org/downloads/clients/all"
  },
  "storage": {
    "target": "all",
    "paths": ["/"]
  }
}